# =============================================================================
# Sprawl — .gitignore
# =============================================================================

# ---------------------
# Rust / Cargo
# ---------------------
/target/
**/*.rs.bk
*.pdb
# Cargo.lock IS committed for this binary workspace.
# This enables reproducible builds and is required by cargo-audit CI.


# ---------------------
# Build artifacts
# ---------------------
*.so
*.dylib
*.dll
*.o
*.a
*.lib
*.exe
*.out

# ---------------------
# WASM build artifacts (plugin development)
# ---------------------
plugins/target/
plugins/**/target/
*.wasm.map
Documents/Implementation/*
# ---------------------
# IDE / Editor
# ---------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# ---------------------
# OS generated
# ---------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ---------------------
# Sprawl runtime data (never commit user state)
# ---------------------
# These would exist at ~/.sprawl/ in production,
# but during development/testing they may appear locally.
ledger.db
ledger.db-journal
ledger.db-wal
manifest.json
models/*.gguf
backups/

# ---------------------
# Test fixtures (generated, not source)
# ---------------------
tests/fixtures/generated/
tests/tmp/
test-results/
coverage/
*.profraw
*.profdata
lcov.info
tarpaulin-report.html

# ---------------------
# Documentation build
# ---------------------
docs/build/
site/

# ---------------------
# Environment / Secrets
# ---------------------
.env
.env.local
.env.*.local
*.pem
*.key

# ---------------------
# Miscellaneous
# ---------------------
*.log
*.bak
*.tmp
*.temp
